#!/bin/bash

set -eo pipefail

if [[ ! "$1" ]]; then
    echo "provide target" >&2
    exit 1
fi

if [[ ! -f "$1" ]]; then
    echo "provide normal file" >&2
    exit 1
fi

abs="$(resolvepath "$1")"
relative="${abs#"$HOME"}"

destdir="$HOME/dotfiles/synced/$(dirname "$relative")"
mkdir -p "$destdir"
mv "$abs" "$destdir"

~/dotfiles/bin/sync
