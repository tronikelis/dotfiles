#!/bin/bash

set -eu

if [[ ! "${1-}" ]]; then
    echo "provide filename"
    exit 1
fi

if [[ ! -f "$1" ]]; then
    echo "provide a normal file"
    exit 1
fi

function atomic_move_without_permissions {
    local dst="$1"
    local src="$2"

    local dir="$(sudo mktemp -d)"
    sudo cp "$dst" "$dir"
    local from="$dir/$(basename "$dst")"

    cat "$src" | sudo tee "$from" >/dev/null
    sudo mv "$from" "$dst"
}

dir="$(mktemp -d)/$(dirname "$1")"
dir="${dir%/.}"
mkdir -p "$dir"
trap 'rm -r "$dir"' EXIT

sudo cp "$1" "$dir"
editable_file="$dir/$(basename "$1")"
sudo chown "$(whoami)" "$editable_file"
"$VISUAL" "$editable_file"

atomic_move_without_permissions "$1" "$editable_file"

echo "written"
