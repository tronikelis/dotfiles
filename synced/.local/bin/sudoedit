#!/bin/bash

set -eu

function sudo_atomic_update {
    local dst="$1"
    local src="$2"
    if [[ ! -e "$dst" ]]; then
        sudo touch "$dst"
    fi

    local from="$(mktemp)"
    sudo cp --preserve=all "$dst" "$from" # "from" now has correct permissions

    cat "$src" | sudo tee "$from" >/dev/null
    sudo mv "$from" "$dst"
}

if [[ ! "${1-}" ]]; then
    echo "provide filename" >&2
    exit 1
fi
target="$1"

if [[ -e "$target" && ! -f "$target" ]]; then
    echo "provide a normal file" >&2
    exit 1
fi

if [[ -e "$target" ]]; then
    target="$(resolvepath "$target")"
else
    # if inlined, script skips errors
    dir="$(resolvepath "$(dirname "$target")")"
    target="$dir/$(basename "$target")"
fi

dir="$(mktemp -d)/$(dirname "$target")"
mkdir -p "$dir"
trap 'rm -r "$dir"' EXIT

editable_file="$dir/$(basename "$target")"
if [[ -e "$target" ]]; then
    sudo cp "$target" "$editable_file"
    sudo chown "$(whoami)" "$editable_file"
fi
"$VISUAL" "$editable_file"

target_sha1="$(sudo cat "$target" 2>/dev/null | sha1sum)"
editable_file_sha1="$(sudo cat "$editable_file" 2>/dev/null | sha1sum)"

if [[ "$target_sha1" == "$editable_file_sha1" ]]; then
    echo "files don't differ, skipping"
    exit 0
fi

sudo_atomic_update "$target" "$editable_file"
