diff --git a/synced/.zsh_plugins/fzf/key-bindings.zsh b/synced/.zsh_plugins/fzf/key-bindings.zsh
index 3b24e30..0e125a0 100644
--- a/synced/.zsh_plugins/fzf/key-bindings.zsh
+++ b/synced/.zsh_plugins/fzf/key-bindings.zsh
@@ -130,12 +130,12 @@ fzf-history-widget() {
   # as the associative 'history' array, which maps event numbers to full history
   # lines, are set. Also, make sure Perl is installed for multi-line output.
   if zmodload -F zsh/parameter p:{commands,history} 2>/dev/null && (( ${+commands[perl]} )); then
-    selected="$(printf '%s\t%s\000' "${(kv)history[@]}" |
+    selected="$(fc -IR; printf '%s\t%s\000' "${(kv)history[@]}" |
