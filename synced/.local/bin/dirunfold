#!/bin/bash

set -eu
shopt -s dotglob

if [[ ! -d "$1" ]]; then
    echo "argument is not directory" >&2
    exit 1
fi

cd "$(dirname "$1")"
dir="$(basename "$1")"

while true; do
    random_id="$RANDOM"
    if [[ ! -e "$dir/$random_id" && ! -e "$random_id" ]]; then
        break
    fi
done

mv "$dir" "$random_id"

mv "$random_id"/* ./
rmdir "$random_id"
